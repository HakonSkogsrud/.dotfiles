{
  // ── Window ──────────────────────────────────────────────
  "window.zoomLevel": 0.8,
  "window.titleBarStyle": "native",
  "window.customTitleBarVisibility": "never",
  "window.menuBarVisibility": "toggle",
  // ── Editor ──────────────────────────────────────────────
  "editor.fontSize": 13,
  "editor.fontFamily": "Hack Nerd Font Mono",
  "editor.minimap.enabled": false,
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "none",
  "editor.selectionClipboard": false,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.scrollbar.verticalScrollbarSize": 6,
  "editor.scrollbar.horizontalScrollbarSize": 6,
  // ── Terminal ────────────────────────────────────────────
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "CommitMono Nerd Font Mono",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.allowChords": false,
  // ── Workbench & Theme ───────────────────────────────────
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "symbols",
  "workbench.preferredLightColorTheme": "Light Modern",
  "workbench.preferredDarkColorTheme": "Dark Modern",
  "workbench.colorCustomizations": {
    "[Light Modern]": {
      "titleBar.activeBackground": "#f5f5f5",
      "titleBar.inactiveBackground": "#eff0f1",
      "titleBar.border": "#f5f5f5",
      "activityBar.background": "#f5f5f5",
      "activityBar.border": "#f5f5f5",
      "statusBar.background": "#f5f5f5",
      "statusBar.border": "#f5f5f5",
      "sideBar.background": "#f5f5f5",
      "sideBar.border": "#fbfbfb",
      "sideBarSectionHeader.background": "#f5f5f5",
      "editorGroupHeader.tabsBackground": "#f5f5f5",
      "editorGroupHeader.noTabsBackground": "#f5f5f5",
      "editorGroupHeader.tabsBorder": "#f5f5f5",
      "editorGroup.border": "#f5f5f5",
      "tab.activeBackground": "#fbfbfb",
      "tab.activeBorder": "#fbfbfb",
      "tab.inactiveBackground": "#f5f5f5",
      "panel.background": "#f5f5f5",
      "list.activeSelectionBackground": "#fbfbfb",
      "list.inactiveSelectionBackground": "#fbfbfb"
    },
    "[Dark Modern]": {
      "titleBar.activeBackground": "#262A2F",
      "titleBar.inactiveBackground": "#eff0f1",
      "activityBar.background": "#262A2F",
      "activityBar.border": "#262A2F",
      "statusBar.background": "#262A2F",
      "statusBar.border": "#262A2F",
      "sideBar.background": "#262A2F",
      "sideBar.border": "#1f1f1f",
      "sideBarSectionHeader.background": "#262A2F",
      "editor.background": "#1f1f1f",
      "editorGroupHeader.tabsBackground": "#262A2F",
      "tab.activeBackground": "#1f1f1f",
      "tab.activeBorder": "#1f1f1f",
      "tab.inactiveBackground": "#262A2F",
      "panel.background": "#1f1f1f",
      "terminal.background": "#1f1f1f"
    }
  },
  // ── Files & Explorer ────────────────────────────────────
  "files.autoSave": "afterDelay",
  "files.autoSaveWhenNoErrors": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "security.workspace.trust.untrustedFiles": "open",
  // ── Git ─────────────────────────────────────────────────
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  // ── Python ──────────────────────────────────────────────
  "python.defaultInterpreterPath": "/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  // ── Copilot & Chat ──────────────────────────────────────
  "chat.editor.fontSize": 13,
  "chat.instructionsFilesLocations": {
    "README.md": true
  },
  "chat.tools.terminal.autoApprove": {
    "git add": true,
    "git commit": true,
    "git push": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  // ── Extensions ──────────────────────────────────────────
  "hediet.vscode-drawio.resizeImages": null,
  "workbench.colorTheme": "Dark Modern"
}